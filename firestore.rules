rules_version = '2';

// MJC-CAT 시범운영 Firestore Security Rules
// ─────────────────────────────────────────────────────────
// 정책 요약
//   responses/{anonymousId}
//     create: 검증된 페이로드만 허용 (학번·이름 차단, 필수 키 + 길이 한도)
//     read·update·delete: 차단 — 관리자 인증 도입 전까지 콘솔에서만 조회
//
// 본 운영 전환 시:
//   1) Firebase Anonymous Auth 도입 → request.auth.uid == anonymousId 일치 강제
//   2) 관리자용 custom claims(role:'admin') 부여 → read·delete 허용
//   3) students/{studentId} 컬렉션 신설 → AES-256 암호화된 학번·이름 (관리자만 접근)
// (계획서 Ⅺ장, CLAUDE.md §7)

service cloud.firestore {
  match /databases/{database}/documents {

    // 학생 응답 컬렉션
    match /responses/{anonymousId} {
      // 신규 응답 등록 — 클라이언트(익명 학생)가 결과지 진입 시 1회 작성
      allow create: if isValidResponse(request.resource.data, anonymousId);

      // 조회 — 시범운영 단계에서는 관리자 대시보드용으로 임시 허용
      //        ⚠ 본 운영 전환 시 Anonymous Auth + custom claim('admin') 필수
      //        저장된 데이터는 익명ID + 16항목 메타뿐(학번·이름 없음)이라 위험도 낮음
      allow read: if true;

      // 수정·삭제 차단
      allow update, delete: if false;
    }

    // 그 외 경로는 모두 차단
    match /{document=**} {
      allow read, write: if false;
    }

    // ────────────────────────────────────────────────
    // 검증 함수
    // ────────────────────────────────────────────────
    function isValidResponse(data, expectedId) {
      return data.keys().hasAll([
              'anonymousId', 'profile', 'completedAt', 'schemaVersion'
            ])
          && data.anonymousId == expectedId
          && data.anonymousId is string
          && data.anonymousId.size() >= 8
          && data.completedAt is string
          && data.profile is map
          && profileIsClean(data.profile)
          && data.size() <= 200          // 필드 개수 상한 (악성 페이로드 방지)
          ;
    }

    // 학번·이름 같은 식별정보가 절대 들어오지 않게 차단
    // (CLAUDE.md §7 시범운영 16항목 외 수집 금지)
    function profileIsClean(profile) {
      return !profile.keys().hasAny([
              'student_id', 'studentId', '학번',
              'real_name', 'realName', 'name_ko', '이름',
              'phone', 'email', 'address', 'rrn',  // 추가 식별정보 차단
              '주민등록번호', '전화번호'
            ])
          && (!('nickname' in profile) || profile.nickname.size() <= 20);
    }
  }
}
